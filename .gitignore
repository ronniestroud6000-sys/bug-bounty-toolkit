# Scan outputs — never commit scan results of live targets
output/
*.log
*.tmp

# Authorized target list — local only, don't publish targets you're scanning
output/.authorized-targets

# Your personal list of targets being monitored — do NOT commit
# (programs.example.txt IS committed as a template)
programs.txt

# Repomix output — regenerate as needed, don't clutter git history
repomix-output.md
repomix-output.xml

# macOS
.DS_Store
._*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Environment / secrets
.env
.env.*
*.key
*.pem
config.local.*

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Archives
*.zip
*.tar.gz
